# --- 3. CACHE E COMPILADOS DO PYTHON ---
__pycache__/
*.py[cod]
*$py.class
*.so

# --- 4. FERRAMENTAS DE DATA SCIENCE (Jupyter/IPython) ---
.ipynb_checkpoints/
profile_default/
ipython_config.py

# --- 5. TESTES E COBERTURA (Opcional, mas recomendado) ---
.pytest_cache/
.coverage
htmlcov/

